<?xml version="1.0" encoding="utf-8" ?>
<odoo noupdate="1">
    <!-- Create Shipment -->
    <record
        model="ir.cron"
        id="ir_cron_export_shipment_orders_scayle"
        forcecreate="True"
    >
        <field name="name">Scayle - Export Shipment Orders</field>
        <field name="user_id" ref="base.user_root" />
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False" />
        <field ref="sale.model_sale_order" name="model_id" />
        <field name="state">code</field>
        <field name="active" eval="False" />
        <field name="code">model._cron_export_shipment_orders()</field>
    </record>

    <!-- #T-02536 Cron to forward the data to given backend scayle URL -->
    <record id="ir_cron_forward_scayle_order_payload" model="ir.cron">
        <field name="name">Scayle Forward Order Payload</field>
        <field name="model_id" ref="connector_scayle.model_scayle_url" />
        <field
            name="nextcall"
            eval="(DateTime.now().replace(hour=0, minute=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"
        />
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False" />
        <field name="active" eval="False" />
        <field name="code">model._cron_forward_scayle_sale_order_payload()</field>
    </record>

    <!-- # change from MR !1298 -->
    <!-- #T-02668: Export cancel order to scayle -->
    <record id="ir_cron_export_cancel_orders_scayle" model="ir.cron">
        <field name="name">Scayle - Export Remaining Canceled Orders</field>
        <field name="model_id" ref="model_scayle_backend" />
        <field name="state">code</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False" />
        <field name="active" eval="False" />
        <field name="code">model._cron_export_remaining_sale_orders()</field>
    </record>

    <!-- Cron Job for Archiving Customers # T-02818 -->
    <record id="ir_cron_archive_customers" model="ir.cron">
        <field name="name">Archive Customers</field>
        <field name="model_id" ref="base.model_res_partner" />
        <field name="state">code</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False" />
        <field name="active" eval="False" />
        <field name="code">model._cron_archive_customers(limit=50000)</field>
    </record>

</odoo>
